# ─── Database (Neon Postgres) ──────────────────────────────────────────────
# Pooled connection string from your Neon project.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── AI (xAI Grok via Vercel AI Gateway) ───────────────────────────────────
# Powers chat, realtime voice, transcription, and meal-photo vision.
AI_GATEWAY_API_KEY="your-xai-or-ai-gateway-key"
# Optional fallback used only if AI_GATEWAY_API_KEY is unset.
# XAI_API_KEY=""

# ─── Fasten Connect (medical-records sync) — optional ──────────────────────
# Get these from https://portal.connect.fastenhealth.com (use _test_ keys for dev).
FASTEN_PUBLIC_ID="public_test_..."
# Same public id, exposed to the browser for the Stitch widget.
NEXT_PUBLIC_FASTEN_PUBLIC_ID="public_test_..."
# SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_.
FASTEN_PRIVATE_KEY="private_test_..."
FASTEN_API_BASE="https://api.connect.fastenhealth.com/v1"

# ─── Cron (background analyst) — optional ──────────────────────────────────
# Bearer secret that protects POST /api/cron/analyze. Vercel sends it automatically.
CRON_SECRET="a-long-random-string"
